# V10 NEXUS Swarm — Environment Configuration
# ============================================

# Flask
FLASK_APP=app
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-min-32-chars-here

# Database (PostgreSQL on Render)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (optional, for future scaling)
# REDIS_URL=redis://localhost:6379/0

# BingX API (DEMO mode by default)
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_DEMO=true

# Binance API (optional)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Bybit API (optional)
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# OKX API (optional)
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# Telegram Notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Master Key for API key encryption (generate with: openssl rand -hex 32)
MASTER_KEY=your-master-encryption-key-64-hex-chars

# Admin settings
ADMIN_SECRET_KEY=admin-reset-db-secret-key

# Trading Settings
DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,AVAXUSDT,LINKUSDT,DOTUSDT,XRPUSDT,ADAUSDT
DEFAULT_TIMEFRAME=4h
DEFAULT_CONFIDENCE=50
MAX_POSITIONS=5
MAX_LEVERAGE=10
DAILY_LOSS_LIMIT=500
